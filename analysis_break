import re
from openpyxl import Workbook, load_workbook
from openpyxl.styles import Font, PatternFill, Border, Side, Alignment

INPUT_PATH = "sample_analysis.xlsx"
OUTPUT_PATH = "pi_af_analysis_breakdown.xlsx"


def clean_text(value):
    return "" if value is None else str(value)


def safe_excel_literal(value):
    text = "" if value is None else str(value)
    return "'" + text if text.startswith(("=", "+", "-", "@")) else text


def parse_rule_config(config_text):
    text = clean_text(config_text).replace("_x000D_", "").replace(":= ", ":=")
    rows = []

    for part in [p.strip() for p in text.split(";")]:
        if not part:
            continue

        if ":=" in part:
            variable, formula = part.split(":=", 1)
            rows.append((variable.strip(), formula.strip()))
        else:
            rows.append((part.strip(), ""))

    return rows


def parse_variable_mapping(mapping_text):
    mapping = {}
    ordered = []

    for part in [p.strip() for p in clean_text(mapping_text).split(";")]:
        if not part:
            continue

        if " || " in part:
            variable, attribute = part.split(" || ", 1)
        elif "||" in part:
            variable, attribute = part.split("||", 1)
        else:
            variable, attribute = part, ""

        variable = variable.strip()
        attribute = attribute.strip()

        if variable:
            mapping[variable] = attribute
            ordered.append((variable, attribute))

    return mapping, ordered


def sanitize_sheet_name(name, used_names):
    raw = clean_text(name).strip() or "Analysis"
    cleaned = re.sub(r"[\[\]\:\*\?\/\\]", "_", raw)
    cleaned = re.sub(r"\s+", " ", cleaned).strip() or "Analysis"

    base = cleaned[:31]
    candidate = base
    counter = 1

    lower_used = {x.lower() for x in used_names}

    while candidate.lower() in lower_used:
        suffix = f"_{counter}"
        candidate = base[:31 - len(suffix)] + suffix
        counter += 1

    used_names.add(candidate)
    return candidate


def find_header_index(headers, exact_name=None, contains_text=None, default=0):
    for i, header in enumerate(headers):
        if exact_name and header == exact_name:
            return i

    if contains_text:
        for i, header in enumerate(headers):
            if contains_text in header:
                return i

    return default


def write_rows(ws, rows):
    for row in rows:
        ws.append(row)


def style_sheet(ws, header_cols):
    header_fill = PatternFill("solid", fgColor="EAF2F8")
    header_font = Font(bold=True, color="1F2937", size=11)
    body_font = Font(color="111827", size=10)

    thin_header = Side(style="thin", color="CBD5E1")
    thin_body = Side(style="thin", color="E5E7EB")

    header_border = Border(bottom=thin_header)
    body_border = Border(
        left=thin_body,
        right=thin_body,
        top=thin_body,
        bottom=thin_body,
    )

    for cell in ws[1]:
        cell.fill = header_fill
        cell.font = header_font
        cell.border = header_border
        cell.alignment = Alignment(
            horizontal="center",
            vertical="center",
            wrap_text=True,
        )

    for row in ws.iter_rows(min_row=2, max_row=ws.max_row, max_col=header_cols):
        for cell in row:
            cell.font = body_font
            cell.border = body_border
            cell.alignment = Alignment(vertical="top", wrap_text=True)

    ws.freeze_panes = "A2"


def main():
    wb_in = load_workbook(INPUT_PATH, data_only=False)
    input_sheet = wb_in.worksheets[0]

    data = list(input_sheet.iter_rows(values_only=True))

    if not data:
        raise ValueError("Input workbook is empty.")

    headers = [clean_text(x).strip().lower() for x in data[0]]

    name_idx = find_header_index(headers, exact_name="name", contains_text="name", default=0)
    config_idx = find_header_index(headers, contains_text="analysisruleconfigstring", default=1)
    mapping_idx = find_header_index(headers, contains_text="analysisrulevariablemapping", default=2)

    processed = []

    for source_row, row in enumerate(data[1:], start=2):
        row = list(row)

        analysis_name = clean_text(row[name_idx] if name_idx < len(row) else "").strip() or f"Row {source_row}"
        config_text = row[config_idx] if config_idx < len(row) else ""
        mapping_text = row[mapping_idx] if mapping_idx < len(row) else ""

        if not clean_text(config_text).strip() and not clean_text(mapping_text).strip():
            continue

        formula_rows = parse_rule_config(config_text)
        mapping_dict, mapping_ordered = parse_variable_mapping(mapping_text)

        output_rows = []
        seen_vars = set()

        for variable, formula in formula_rows:
            seen_vars.add(variable)
            output_rows.append([
                variable,
                formula,
                mapping_dict.get(variable, ""),
            ])

        for variable, attribute in mapping_ordered:
            if variable not in seen_vars:
                output_rows.append([
                    variable,
                    "",
                    attribute,
                ])

        processed.append({
            "source_row": source_row,
            "analysis_name": analysis_name,
            "rows": output_rows,
            "formula_count": len(formula_rows),
            "mapping_count": len(mapping_ordered),
            "matched_count": sum(1 for variable, _ in formula_rows if variable in mapping_dict),
            "unmatched_mapping_count": sum(1 for variable, _ in mapping_ordered if variable not in seen_vars),
        })

    wb_out = Workbook()

    summary = wb_out.active
    summary.title = "Summary"

    used_names = {"Summary", "Consolidated_All"}

    summary_rows = [[
        "Source Row",
        "Analysis Name",
        "Output Sheet",
        "Formula Rows",
        "Mapping Rows",
        "Matched Mapping Rows",
        "Unmatched Mapping Rows",
    ]]

    consolidated_rows = [[
        "Analysis Name",
        "Variable",
        "Formula",
        "Mapping Attribute",
    ]]

    for item in processed:
        sheet_name = sanitize_sheet_name(item["analysis_name"], used_names)
        ws = wb_out.create_sheet(sheet_name)

        rows = [["Variable", "Formula", "Mapping Attribute"]]

        for variable, formula, attribute in item["rows"]:
            safe_row = [
                safe_excel_literal(variable),
                safe_excel_literal(formula),
                safe_excel_literal(attribute),
            ]

            rows.append(safe_row)

            consolidated_rows.append([
                safe_excel_literal(item["analysis_name"]),
                safe_excel_literal(variable),
                safe_excel_literal(formula),
                safe_excel_literal(attribute),
            ])

        write_rows(ws, rows)
        style_sheet(ws, 3)

        ws.column_dimensions["A"].width = 34
        ws.column_dimensions["B"].width = 95
        ws.column_dimensions["C"].width = 42

        summary_rows.append([
            item["source_row"],
            item["analysis_name"],
            sheet_name,
            item["formula_count"],
            item["mapping_count"],
            item["matched_count"],
            item["unmatched_mapping_count"],
        ])

    write_rows(summary, summary_rows)
    style_sheet(summary, 7)

    summary.column_dimensions["A"].width = 12
    summary.column_dimensions["B"].width = 42
    summary.column_dimensions["C"].width = 34
    summary.column_dimensions["D"].width = 18
    summary.column_dimensions["E"].width = 18
    summary.column_dimensions["F"].width = 22
    summary.column_dimensions["G"].width = 24

    consolidated = wb_out.create_sheet("Consolidated_All")
    write_rows(consolidated, consolidated_rows)
    style_sheet(consolidated, 4)

    consolidated.column_dimensions["A"].width = 42
    consolidated.column_dimensions["B"].width = 34
    consolidated.column_dimensions["C"].width = 95
    consolidated.column_dimensions["D"].width = 42

    wb_out.save(OUTPUT_PATH)


if __name__ == "__main__":
    main()
