def get_header_col(ws, header_names):
    wanted = {h.strip().lower() for h in header_names}

    for c in range(1, ws.max_column + 1):
        value = ws.cell(1, c).value
        if value is None:
            continue

        header = str(value).strip().lower()
        if header in wanted:
            return c

    return None
