def detect_formula_columns(ws):
    headers = {
        str(ws.cell(1, c).value).strip().lower(): c
        for c in range(1, ws.max_column + 1)
        if ws.cell(1, c).value is not None
    }

    var_col = None
    formula_col = None

    for key, col in headers.items():
        if key in {"variable_names", "variable names", "variable_name", "variablename"}:
            var_col = col
        if key in {"formulas", "formula", "analysis rule config string", "analysis_rule_config_string"}:
            formula_col = col

    if var_col is None:
        for key, col in headers.items():
            if "variable" in key and "mapping" not in key:
                var_col = col
                break

    if formula_col is None:
        for key, col in headers.items():
            if "formula" in key or "config string" in key:
                formula_col = col
                break

    return var_col, formula_col


def get_or_create_output_columns(ws):
    headers = {
        str(ws.cell(1, c).value).strip(): c
        for c in range(1, ws.max_column + 1)
        if ws.cell(1, c).value is not None
    }

    rm_var_col = headers.get("RapidMiner_Variable_Name")
    rm_formula_col = headers.get("RapidMiner_Formula")

    next_col = ws.max_column + 1

    if rm_var_col is None:
        rm_var_col = next_col
        ws.cell(1, rm_var_col).value = "RapidMiner_Variable_Name"
        next_col += 1

    if rm_formula_col is None:
        rm_formula_col = next_col
        ws.cell(1, rm_formula_col).value = "RapidMiner_Formula"

    return rm_var_col, rm_formula_col


def extract_existing_input_values(input_ws):
    if input_ws is None:
        return {}

    headers = {
        str(input_ws.cell(1, c).value).strip(): c
        for c in range(1, input_ws.max_column + 1)
        if input_ws.cell(1, c).value is not None
    }

    original_col = headers.get("Original_Input_Name")
    value_col = headers.get("Value")

    values = {}
    if original_col and value_col:
        for r in range(2, input_ws.max_row + 1):
            key = input_ws.cell(r, original_col).value
            if key is not None:
                values[str(key)] = input_ws.cell(r, value_col).value

    return values


def make_unique_sheet_name(base_name: str, existing_names) -> str:
    name = base_name
    counter = 2

    while name in existing_names:
        suffix = f"_{counter}"
        max_base_len = 31 - len(suffix)
        name = base_name[:max_base_len] + suffix
        counter += 1

    return name


def build_input_sheet_name(source_sheet_name: str, existing_names) -> str:
    # Excel sheet name limit is 31 chars.
    clean_name = str(source_sheet_name).rstrip()
    max_base_len = 31 - len(INPUT_SUFFIX)
    base_name = clean_name[:max_base_len] + INPUT_SUFFIX
    return make_unique_sheet_name(base_name, set(existing_names))


def create_side_by_side_input_sheet(wb, source_ws, inputs):
    source_index = wb.sheetnames.index(source_ws.title)

    existing_values = {}
    sheet_to_delete = None

    # If the next tab is already an RM input sheet, reuse its values and replace it.
    if source_index + 1 < len(wb.sheetnames):
        next_name = wb.sheetnames[source_index + 1]
        if next_name.endswith(INPUT_SUFFIX):
            existing_values = extract_existing_input_values(wb[next_name])
            sheet_to_delete = next_name

    existing_names_for_new = list(wb.sheetnames)
    if sheet_to_delete:
        existing_names_for_new = [n for n in existing_names_for_new if n != sheet_to_delete]

    new_input_sheet_name = build_input_sheet_name(source_ws.title, existing_names_for_new)

    # If same target name exists elsewhere, preserve values and replace it.
    if new_input_sheet_name in wb.sheetnames and new_input_sheet_name != sheet_to_delete:
        existing_values = extract_existing_input_values(wb[new_input_sheet_name]) or existing_values
        del wb[new_input_sheet_name]

    if sheet_to_delete and sheet_to_delete in wb.sheetnames:
        del wb[sheet_to_delete]
        source_index = wb.sheetnames.index(source_ws.title)

    input_ws = wb.create_sheet(title=new_input_sheet_name, index=source_index + 1)
    input_ws.append(["Original_Input_Name", "Value", "RapidMiner_Input_Name"])

    for original_name, rm_name in inputs:
        input_ws.append([original_name, existing_values.get(original_name), rm_name])

    return input_ws.title


def process_formula_sheet(wb, ws):
    var_col, formula_col = detect_formula_columns(ws)
    if not var_col or not formula_col:
        return None

    rm_var_col, rm_formula_col = get_or_create_output_columns(ws)
    input_map = {}

    for r in range(2, ws.max_row + 1):
        var_value = ws.cell(r, var_col).value
        formula_value = ws.cell(r, formula_col).value

        if var_value is not None:
            var_name = str(var_value).strip()
            ws.cell(r, rm_var_col).value = var_name[1:] if var_name.startswith("v") else var_name

        if formula_value is None:
            continue

        if isinstance(formula_value, (int, float)):
            ws.cell(r, rm_formula_col).value = formula_value
        else:
            formula_text = str(formula_value).strip()
            if formula_text == "":
                ws.cell(r, rm_formula_col).value = ""
            else:
                ws.cell(r, rm_formula_col).value = transform_expression(formula_text, input_map)

    sorted_inputs = sorted(input_map.items(), key=lambda x: x[0].lower())
    rm_input_sheet_name = create_side_by_side_input_sheet(wb, ws, sorted_inputs)

    return {
        "sheet_name": ws.title,
        "rm_input_sheet_name": rm_input_sheet_name,
        "input_count": len(sorted_inputs),
        "row_count": ws.max_row - 1,
    }


def should_process_sheet(ws) -> bool:
    if ws.title.endswith(INPUT_SUFFIX):
        return False
    var_col, formula_col = detect_formula_columns(ws)
    return bool(var_col and formula_col)


def process_workbook(input_path: str, output_path: str, requested_sheets=None):
    wb = load_workbook(input_path)

    sheet_names = list(wb.sheetnames)
    results = []
    skipped = []

    for sheet_name in sheet_names:
        if sheet_name not in wb.sheetnames:
            continue

        ws = wb[sheet_name]

        if requested_sheets is not None and sheet_name not in requested_sheets:
            skipped.append((sheet_name, "not in SHEETS_TO_PROCESS"))
            continue

        if not should_process_sheet(ws):
            skipped.append((sheet_name, "no formula/variable columns detected"))
            continue

        result = process_formula_sheet(wb, ws)
        if result:
            results.append(result)
        else:
            skipped.append((sheet_name, "sheet skipped"))

    wb.save(output_path)

    print(f"Input workbook : {input_path}")
    print(f"Output workbook: {output_path}")
    print("-" * 60)

    if results:
        print("Processed sheets:")
        for item in results:
            print(
                f"  - {item['sheet_name']}  ->  {item['rm_input_sheet_name']} "
                f"(rows={item['row_count']}, inputs={item['input_count']})"
            )
    else:
        print("No eligible formula sheets found.")

    if skipped:
        print("-" * 60)
        print("Skipped sheets:")
        for name, reason in skipped:
            print(f"  - {name}: {reason}")


