# HELPERS
# =========================
def collapse_outer_parens(expr: str) -> str:
    expr = expr.strip()
    while expr.startswith("(") and expr.endswith(")"):
        depth = 0
        in_quote = False
        ok = True
        for i, ch in enumerate(expr):
            if ch == "'" and (i == 0 or expr[i - 1] != "\\"):
                in_quote = not in_quote
            elif not in_quote:
                if ch == "(":
                    depth += 1
                elif ch == ")":
                    depth -= 1
                    if depth == 0 and i != len(expr) - 1:
                        ok = False
                        break
        if ok and depth == 0:
            expr = expr[1:-1].strip()
        else:
            break
    return expr


def find_matching_paren(text: str, open_idx: int) -> int:
    depth = 0
    in_quote = False
    i = open_idx
    while i < len(text):
        ch = text[i]
        if ch == "'" and (i == 0 or text[i - 1] != "\\"):
            in_quote = not in_quote
        elif not in_quote:
            if ch == "(":
                depth += 1
            elif ch == ")":
                depth -= 1
                if depth == 0:
                    return i
        i += 1
    return -1


def split_top_level_args(text: str):
    if text.strip() == "":
        return []

    args = []
    start = 0
    depth = 0
    in_quote = False

    for i, ch in enumerate(text):
        if ch == "'" and (i == 0 or text[i - 1] != "\\"):
            in_quote = not in_quote
        elif not in_quote:
            if ch == "(":
                depth += 1
            elif ch == ")":
                depth -= 1
            elif ch == "," and depth == 0:
                args.append(text[start:i].strip())
                start = i + 1

    args.append(text[start:].strip())
    return args


def find_top_level_keyword(text: str, keyword: str) -> int:
    depth = 0
    in_quote = False
    kw = keyword.lower()

    i = 0
    while i <= len(text) - len(keyword):
        ch = text[i]

        if ch == "'" and (i == 0 or text[i - 1] != "\\"):
            in_quote = not in_quote
            i += 1
            continue

        if not in_quote:
            if ch == "(":
                depth += 1
            elif ch == ")":
                depth -= 1

            if depth == 0 and text[i:i + len(keyword)].lower() == kw:
                prev = text[i - 1] if i > 0 else " "
                nxt = text[i + len(keyword)] if i + len(keyword) < len(text) else " "
                if not (prev.isalnum() or prev == "_") and not (nxt.isalnum() or nxt == "_"):
                    return i
        i += 1

    return -1


def parse_if(expr: str):
    expr = expr.strip()
    if expr[:2].lower() != "if":
        return None

    rest = expr[2:].lstrip()
    then_idx = find_top_level_keyword(rest, "Then")
    if then_idx == -1:
        return None

    condition = rest[:then_idx].strip()
    rest_after_then = rest[then_idx + 4:].lstrip()

    else_idx = find_top_level_keyword(rest_after_then, "Else")
    if else_idx == -1:
        return None

    true_part = rest_after_then[:else_idx].strip()
    false_part = rest_after_then[else_idx + 4:].strip()

    return condition, true_part, false_part


def sanitize_name(name: str) -> str:
    safe = re.sub(r"[^0-9A-Za-z_]+", "_", str(name))
    safe = re.sub(r"_+", "_", safe).strip("_")
    return safe


def make_input_alias(original_name: str) -> str:
    original_name = str(original_name)

    if original_name.endswith("|Lo"):
        return "inp_" + sanitize_name(original_name[:-3]) + "_Lo"
    if original_name.endswith("|Hi"):
        return "inp_" + sanitize_name(original_name[:-3]) + "_Hi"
    if original_name.endswith("|DF"):
        return "inp_" + sanitize_name(original_name[:-3]) + "_DF"
    if original_name.endswith("|DS"):
        return "inp_" + sanitize_name(original_name[:-3]) + "_DS"
    if original_name.endswith("|Prev"):
        return "inp_" + sanitize_name(original_name[:-5]) + "_Prev"

    return "inp_" + sanitize_name(original_name)


def transform_composite(expr: str, input_map: dict) -> str:
    out = []
    i = 0

    while i < len(expr):
        ch = expr[i]

        # Quoted reference -> input attribute
        if ch == "'":
            j = i + 1
            while j < len(expr):
                if expr[j] == "'" and expr[j - 1] != "\\":
                    break
                j += 1

            inner = expr[i + 1:j]
            if inner not in input_map:
                input_map[inner] = make_input_alias(inner)

            out.append(f"[{input_map[inner]}]")
            i = j + 1
            continue

        # Word / variable / function
        if ch.isalpha() or ch == "_":
            j = i + 1
            while j < len(expr) and (expr[j].isalnum() or expr[j] == "_"):
                j += 1

            word = expr[i:j]

            k = j
            while k < len(expr) and expr[k].isspace():
                k += 1

            # Function call
            if k < len(expr) and expr[k] == "(":
                end = find_matching_paren(expr, k)
                if end != -1:
                    func_text = expr[i:end + 1]
                    out.append(transform_expression(func_text, input_map))
                    i = end + 1
                    continue

            # Internal variable with leading v
            if word.startswith("v") and len(word) > 1 and (word[1].isalpha() or word[1] == "_"):
                out.append(f"[{word[1:]}]")
            else:
                out.append(word)

            i = j
            continue

        out.append(ch)
        i += 1

    text = "".join(out)

    text = re.sub(r"(?i)\bAND\b", "and", text)
    text = re.sub(r"(?i)\bOR\b", "or", text)
    text = re.sub(r"(?i)\bNOT\b", "not", text)

    text = text.replace("<>", "!=")
    text = re.sub(r"(?<![<>=!])=(?!=)", "==", text)
    text = re.sub(r"\s+", " ", text).strip()

    return text


def transform_expression(expr: str, input_map: dict) -> str:
    expr = collapse_outer_parens(str(expr).strip())

    parsed_if = parse_if(expr)
    if parsed_if:
        condition, true_part, false_part = parsed_if
        return (
            f"if({transform_expression(condition, input_map)}, "
            f"{transform_expression(true_part, input_map)}, "
            f"{transform_expression(false_part, input_map)})"
        )

    func_match = re.match(r"^([A-Za-z_][A-Za-z0-9_]*)\s*\((.*)\)$", expr, flags=re.S)
    if func_match:
        fname = func_match.group(1)
        open_idx = expr.find("(")

        if find_matching_paren(expr, open_idx) == len(expr) - 1:
            inner = expr[open_idx + 1:-1]
            args = split_top_level_args(inner)
            fname_l = fname.lower()

            if fname_l == "median" and len(args) == 3:
                lo = transform_expression(args[0], input_map)
                val = transform_expression(args[1], input_map)
                hi = transform_expression(args[2], input_map)
                return f"min(max({val}, {lo}), {hi})"

            if fname_l == "badval" and len(args) == 1:
                return f"missing({transform_expression(args[0], input_map)})"

            if fname_l == "nooutput" and len(args) == 0:
                return NO_OUTPUT_TOKEN

            if fname_l == "prevval" and len(args) >= 1:
                first_arg = args[0].strip()
                m = re.fullmatch(r"'([^']*)'", first_arg)
                if m:
                    prev_name = m.group(1) + "|Prev"
                    if prev_name not in input_map:
                        input_map[prev_name] = make_input_alias(prev_name)
                    return f"[{input_map[prev_name]}]"

                fallback_name = "PrevValue"
                if fallback_name not in input_map:
                    input_map[fallback_name] = make_input_alias(fallback_name)
                return f"[{input_map[fallback_name]}]"

            transformed_args = [transform_expression(arg, input_map) for arg in args]
            generic_name = fname.lower() if fname.lower() in {
                "min", "max", "abs", "sqrt", "exp", "ln", "log",
                "sin", "cos", "tan", "round", "floor", "ceil", "pow"
            } else fname

            return f"{generic_name}(" + ", ".join(transformed_args) + ")"

    return transform_composite(expr, input_map)


