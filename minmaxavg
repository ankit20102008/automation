from __future__ import annotations

import re
from pathlib import Path
from typing import Iterable

from openpyxl import load_workbook


# Functions to transform
TARGET_FUNCS = {"MAX", "MIN", "AVERAGE"}

# Missing values will be replaced with this
DEFAULT_MISSING_VALUE = "0"


def is_numeric_literal(text: str) -> bool:
    """Return True if text looks like a numeric literal."""
    return bool(
        re.fullmatch(r"[+-]?(?:\d+(?:\.\d*)?|\.\d+)(?:[Ee][+-]?\d+)?", text.strip())
    )


def should_wrap_argument(arg: str) -> bool:
    """
    Decide whether an argument should be wrapped with IF(IS_MISSING(...), default, ...).
    Constants like numbers, strings, TRUE/FALSE are left unchanged.
    """
    s = arg.strip()
    if not s:
        return False
    if s.startswith('"') and s.endswith('"'):
        return False
    if is_numeric_literal(s):
        return False
    if s.upper() in {"TRUE", "FALSE"}:
        return False
    return True


def already_wrapped(arg: str) -> bool:
    """Avoid wrapping something that already starts with IF(IS_MISSING(...))."""
    s = arg.strip()
    return bool(re.match(r"(?is)^IF\s*\(\s*IS_MISSING\s*\(", s))


def split_top_level_args(text: str) -> list[str]:
    """
    Split function arguments by top-level commas only.
    Handles nested functions, strings, sheet names, arrays, and structured refs.
    """
    args = []
    start = 0
    paren = brace = bracket = 0
    in_double_quote = False
    in_single_quote = False
    i = 0

    while i < len(text):
        ch = text[i]

        if in_double_quote:
            if ch == '"':
                if i + 1 < len(text) and text[i + 1] == '"':  # Escaped ""
                    i += 2
                    continue
                in_double_quote = False
            i += 1
            continue

        if in_single_quote:
            if ch == "'":
                if i + 1 < len(text) and text[i + 1] == "'":  # Escaped ''
                    i += 2
                    continue
                in_single_quote = False
            i += 1
            continue

        if ch == '"':
            in_double_quote = True
        elif ch == "'":
            in_single_quote = True
        elif ch == "(":
            paren += 1
        elif ch == ")":
            paren -= 1
        elif ch == "{":
            brace += 1
        elif ch == "}":
            brace -= 1
        elif ch == "[":
            bracket += 1
        elif ch == "]":
            bracket -= 1
        elif ch == "," and paren == 0 and brace == 0 and bracket == 0:
            args.append(text[start:i])
            start = i + 1

        i += 1

    args.append(text[start:])
    return args


def find_matching_paren(text: str, open_paren_idx: int) -> int:
    """Find the matching ')' for the '(' at open_paren_idx."""
    if text[open_paren_idx] != "(":
        raise ValueError("Expected '(' at open_paren_idx")

    depth = 1
    in_double_quote = False
    in_single_quote = False
    i = open_paren_idx + 1

    while i < len(text):
        ch = text[i]

        if in_double_quote:
            if ch == '"':
                if i + 1 < len(text) and text[i + 1] == '"':
                    i += 2
                    continue
                in_double_quote = False
            i += 1
            continue

        if in_single_quote:
            if ch == "'":
                if i + 1 < len(text) and text[i + 1] == "'":
                    i += 2
                    continue
                in_single_quote = False
            i += 1
            continue

        if ch == '"':
            in_double_quote = True
        elif ch == "'":
            in_single_quote = True
        elif ch == "(":
            depth += 1
        elif ch == ")":
            depth -= 1
            if depth == 0:
                return i

        i += 1

    raise ValueError(f"Unmatched '(' in formula text: {text}")


def looks_like_exact_function_call(text: str, names: set[str] | None = None) -> bool:
    """
    Return True if text is exactly one function call, e.g. MIN(A,B)
    and not something like MIN(A,B)+1
    """
    s = text.strip()
    match = re.match(r"(?is)^([A-Z_][A-Z0-9_\.]*)\s*\(", s)
    if not match:
        return False

    func_name = match.group(1).upper()
    if names and func_name not in names:
        return False

    open_idx = s.find("(")
    try:
        close_idx = find_matching_paren(s, open_idx)
    except ValueError:
        return False

    return close_idx == len(s) - 1


def wrap_argument(arg: str, default_value: str) -> str:
    """
    Transform nested target functions inside the argument, then wrap the argument itself
    if needed.
    """
    transformed = transform_expression(arg, default_value).strip()

    if not should_wrap_argument(transformed):
        return transformed

    if already_wrapped(transformed):
        return transformed

    # If the argument is itself exactly MAX/MIN/AVERAGE(...), do not wrap again.
    # Its internal arguments are already handled recursively.
    if looks_like_exact_function_call(transformed, TARGET_FUNCS):
        return transformed

    return f"IF(IS_MISSING({transformed}), {default_value}, {transformed})"


def transform_function_call(func_name: str, inner_text: str, default_value: str) -> str:
    """
    Transform a function call body.
    For MAX/MIN/AVERAGE, wrap each direct argument.
    For all other functions, just recurse inside.
    """
    if func_name.upper() in TARGET_FUNCS:
        args = split_top_level_args(inner_text)
        transformed_args = [wrap_argument(arg, default_value) for arg in args]
        return ", ".join(transformed_args)

    return transform_expression(inner_text, default_value)


def transform_expression(text: str, default_value: str = DEFAULT_MISSING_VALUE) -> str:
    """
    Recursively transform formula text.
    """
    result = []
    i = 0

    while i < len(text):
        ch = text[i]

        # Excel string literal: "text"
        if ch == '"':
            start = i
            i += 1
            while i < len(text):
                if text[i] == '"':
                    if i + 1 < len(text) and text[i + 1] == '"':
                        i += 2
                        continue
                    i += 1
                    break
                i += 1
            result.append(text[start:i])
            continue

        # Quoted sheet/workbook name: 'My Sheet'!A1
        if ch == "'":
            start = i
            i += 1
            while i < len(text):
                if text[i] == "'":
                    if i + 1 < len(text) and text[i + 1] == "'":
                        i += 2
                        continue
                    i += 1
                    break
                i += 1
            result.append(text[start:i])
            continue

        # Function / identifier
        if ch.isalpha() or ch in {"_", "."}:
            start = i
            i += 1
            while i < len(text) and (text[i].isalnum() or text[i] in {"_", "."}):
                i += 1

            token = text[start:i]

            # Preserve whitespace between function name and '(' if any
            ws_start = i
            while i < len(text) and text[i].isspace():
                i += 1

            if i < len(text) and text[i] == "(":
                end = find_matching_paren(text, i)
                inner = text[i + 1:end]
                new_inner = transform_function_call(token, inner, default_value)

                result.append(token)
                result.append(text[ws_start:i])
                result.append("(")
                result.append(new_inner)
                result.append(")")

                i = end + 1
            else:
                result.append(text[start:i])

            continue

        result.append(ch)
        i += 1

    return "".join(result)


def transform_formula(formula: str, default_value: str = DEFAULT_MISSING_VALUE) -> str:
    """Transform a full Excel formula string."""
    if not isinstance(formula, str) or not formula.startswith("="):
        return formula
    return "=" + transform_expression(formula[1:], default_value)


def process_workbook(
    input_file: str | Path,
    output_file: str | Path,
    sheets: Iterable[str] | None = None,
    default_value: str = DEFAULT_MISSING_VALUE,
) -> None:
    """
    Open an Excel workbook, update formulas in-place, and save to a new file.
    """
    input_file = Path(input_file)
    output_file = Path(output_file)

    wb = load_workbook(input_file)

    target_sheets = wb.sheetnames if sheets is None else list(sheets)

    changed_cells = 0

    for sheet_name in target_sheets:
        ws = wb[sheet_name]

        for row in ws.iter_rows():
            for cell in row:
                if isinstance(cell.value, str) and cell.value.startswith("="):
                    old_formula = cell.value
                    new_formula = transform_formula(old_formula, default_value)

                    if new_formula != old_formula:
                        cell.value = new_formula
                        changed_cells += 1

    wb.save(output_file)
    print(f"Done. Updated {changed_cells} formula cell(s).")
    print(f"Saved to: {output_file}")


if __name__ == "__main__":
    # Example:
